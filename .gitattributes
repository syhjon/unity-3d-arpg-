* text=auto

# Unity/YAML text assets
*.asmdef text eol=lf
*.asmref text eol=lf
*.asset text eol=lf
*.controller text eol=lf
*.inputactions text eol=lf
*.mat text eol=lf
*.meta text eol=lf
*.overrideController text eol=lf
*.physicMaterial text eol=lf
